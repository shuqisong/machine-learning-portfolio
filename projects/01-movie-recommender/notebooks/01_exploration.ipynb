      "ratings: 100,836 rows x 4 columns\n",
      "\n",
      "Unique users:  610\n",
      "Unique movies rated: 9,724\n"
     ]
    }
   ],
   "source": [
    "movies = pd.read_csv(RAW / \"movies.csv\")\n",
    "ratings = pd.read_csv(RAW / \"ratings.csv\")\n",
    "\n",
    "print(f\"movies:  {movies.shape[0]:,} rows x {movies.shape[1]} columns\")\n",
    "print(f\"ratings: {ratings.shape[0]:,} rows x {ratings.shape[1]} columns\")\n",
    "print(f\"\\nUnique users:  {ratings['userId'].nunique():,}\")\n",
    "print(f\"Unique movies rated: {ratings['movieId'].nunique():,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
